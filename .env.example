NEXT_PUBLIC_GOOGLE_MAPS_API_KEY=
# Separate server-only key for Geocoding API. Do not reuse the browser key.
GOOGLE_MAPS_API_KEY=
GOOGLE_SOLAR_API_KEY=

# Supabase CRM/Auth.
# Use the new publishable key when available. Legacy anon key is also supported by the code.
NEXT_PUBLIC_SUPABASE_URL=
NEXT_PUBLIC_SUPABASE_PUBLISHABLE_KEY=
NEXT_PUBLIC_SUPABASE_ANON_KEY=
# Server-only. Never expose this value through a NEXT_PUBLIC_ variable.
SUPABASE_SERVICE_ROLE_KEY=

# Public account creation is disabled unless this server-only flag is explicitly true.
# Supabase Auth signup must also be deliberately enabled for a controlled signup window.
KSOLAR_ENABLE_PUBLIC_SIGNUP=false
